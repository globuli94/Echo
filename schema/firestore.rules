rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // users/{uid}
    // ---------------------------------------------------------------
    match /users/{uid} {
      // Any authenticated user may read any user profile.
      allow read: if request.auth != null;

      // Only the owner may create their own document, and only when
      // the document ID matches their auth UID.
      allow create: if request.auth != null
                    && request.auth.uid == uid;

      // Updates are restricted:
      //   - The owner may update their own mutable profile fields.
      //   - Any authenticated user may increment followerCount or
      //     followingCount (FieldValue.increment from follow/unfollow flow).
      allow update: if request.auth != null
                    && (
                      // Owner profile-field update path
                      (
                        request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['displayName', 'bio', 'avatarUrl'])
                      )
                      ||
                      // Third-party follower/following count update path
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['followerCount', 'followingCount'])
                    );

      // Deletion of user documents is not permitted via the client SDK.
      allow delete: if false;

      // ---------------------------------------------------------------
      // users/{uid}/following/{targetUid}
      // ---------------------------------------------------------------
      match /following/{targetUid} {
        // Any authenticated user may read a following document
        // (e.g. to check if a follow relationship exists).
        allow read: if request.auth != null;

        // Only the follower (document parent uid == auth.uid) may
        // create or delete their own follow documents.
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.targetUid == targetUid;

        allow delete: if request.auth != null
                      && request.auth.uid == uid;

        // Updates to follow documents are not permitted.
        allow update: if false;
      }

      // ---------------------------------------------------------------
      // users/{uid}/likes/{postId}
      // ---------------------------------------------------------------
      match /likes/{postId} {
        // Any authenticated user may read like documents
        // (e.g. to stream whether they have liked a given post).
        allow read: if request.auth != null;

        // Only the liker (document parent uid == auth.uid) may
        // create or delete their own like documents.
        allow create: if request.auth != null
                      && request.auth.uid == uid;

        allow delete: if request.auth != null
                      && request.auth.uid == uid;

        // Updates to like documents are not permitted.
        allow update: if false;
      }

      // ---------------------------------------------------------------
      // users/{uid}/notifications/{notificationId}
      // ---------------------------------------------------------------
      match /notifications/{notificationId} {
        // Only the owner may read (get or list) their own notifications.
        allow read: if request.auth != null
                    && request.auth.uid == uid;

        // Any authenticated user may create a notification in any user's
        // subcollection (actor writing to recipient's subcollection).
        allow create: if request.auth != null;

        // Only the owner may update a notification, and only to mark it
        // as read (the `read` field).
        allow update: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['read']);

        // Deletion of notification documents is not permitted via the client SDK.
        allow delete: if false;
      }
    }

    // ---------------------------------------------------------------
    // Collection group rule for `following`
    // Enables collection group queries (e.g. FollowersScreen: all users
    // who follow a given user). The nested write rules below remain
    // authoritative for create/delete.
    // ---------------------------------------------------------------
    match /{path=**}/following/{docId} {
      allow read: if request.auth != null;
    }

    // ---------------------------------------------------------------
    // conversations/{conversationId}
    // ---------------------------------------------------------------
    match /conversations/{conversationId} {
      // Helper: requesting user is a participant in this conversation.
      function isParticipant() {
        return request.auth != null
               && request.auth.uid in resource.data.participantIds;
      }

      // Allow an authenticated user to attempt a get on a conversation that
      // may not exist yet (resource == null → doc absent, returns not-found).
      // Existing docs are guarded by the participantIds check.
      allow get: if request.auth != null
                 && (resource == null
                     || request.auth.uid in resource.data.participantIds);

      // List queries always return existing documents, so resource is never
      // null here — guard by participantIds as before.
      allow list: if isParticipant();

      // Authenticated user may create a conversation when:
      //   - auth.uid is listed in participantIds
      //   - exactly 2 participants
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.participantIds.size() == 2;

      // Participants may update only the last-message preview and unread
      // count fields. This covers both the sender updating lastMessage* and
      // the reader zeroing their own unreadCounts entry.
      allow update: if isParticipant()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['lastMessage', 'lastMessageAt',
                                   'lastMessageSenderId', 'unreadCounts']);

      // Deletion of conversation documents is not permitted via the client SDK.
      allow delete: if false;

      // ---------------------------------------------------------------
      // conversations/{conversationId}/messages/{messageId}
      // ---------------------------------------------------------------
      match /messages/{messageId} {
        // Fetch the parent conversation to verify participation.
        function parentParticipants() {
          return get(/databases/$(database)/documents/conversations/$(conversationId))
                   .data.participantIds;
        }

        function isConversationParticipant() {
          return request.auth != null
                 && request.auth.uid in parentParticipants();
        }

        // Participants may read all messages (real-time listener, sorted
        // by createdAt ASC — covered by automatic single-field index).
        allow read: if isConversationParticipant();

        // Participants may create a message; senderId must equal auth.uid.
        allow create: if isConversationParticipant()
                      && request.resource.data.senderId == request.auth.uid;

        // Updates and deletes are not permitted via the client SDK.
        allow update: if false;
        allow delete: if false;
      }
    }

    // ---------------------------------------------------------------
    // posts/{postId}
    // ---------------------------------------------------------------
    match /posts/{postId} {
      // Any authenticated user may read any post.
      allow read: if request.auth != null;

      // Any authenticated user may create a post, but authorId must
      // equal the requesting user's UID.
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;

      // Updates are restricted:
      //   - The owner may update any field on their own post.
      //   - Any authenticated user may update only the likeCount field.
      allow update: if request.auth != null
                    && (
                      // Owner full-update path
                      resource.data.authorId == request.auth.uid
                      ||
                      // Third-party likeCount-only path
                      (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['likeCount'])
                      )
                    );

      // Only the author may delete their own post.
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;

      // ---------------------------------------------------------------
      // posts/{postId}/likes/{uid}
      // ---------------------------------------------------------------
      match /likes/{uid} {
        // Any authenticated user may read a like document
        // (e.g. to check if a specific user liked a post).
        allow read: if request.auth != null;

        // Only the owner (uid == auth.uid) may create their own like
        // document. Enforce that the stored uid field matches both the
        // document ID and the requesting user.
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.uid == uid;

        // Only the owner may delete their own like document.
        allow delete: if request.auth != null
                      && request.auth.uid == uid;

        // Updates to like documents are not permitted.
        allow update: if false;
      }
    }

  }
}
